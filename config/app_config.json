{
    "topics": {
      "odom": "/robot/robotnik_base_control/odom",
      "map": "/map",
      "camera": "/robot/front_rgbd_camera/rgb/image_raw",
      "episode_event": "/experiment/episode_event"
    },
    "slam": {
      "start_command": "bash -lc 'source /opt/ros/melodic/setup.bash; source ~/catkin_ws/devel/setup.bash; roslaunch your_slam_pkg your_slam.launch'",
      "save_map_command": "bash -lc 'source /opt/ros/melodic/setup.bash; rosrun map_server map_saver -f /home/s/maps/latest_map'",
      "stop_command": "bash -lc 'pkill -f your_slam.launch'"
    },
    "paths": {
      "default_map_dir": "/home/s/maps"
    }
  }